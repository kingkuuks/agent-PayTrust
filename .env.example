# ─── AI BRAIN ───────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
KIMI_MODEL=moonshotai/kimi-k2.5

# ─── REDDIT ──────────────────────────────────
REDDIT_CLIENT_ID=xxxxxxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=PayTrustContentAgent/1.0

# ─── TWITTER/X ───────────────────────────────
TWITTER_USERNAME=your_twitter_handle
TWITTER_EMAIL=your@email.com
TWITTER_PASSWORD=yourpassword

# ─── IMAGE GENERATION ────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# Brief/strategist text (optional). Fallback chain adds 2.5-flash, 2.5-flash-lite, 3.1-flash-lite-preview unless already in chain.
# Prefer stable text if preview hits quota: GEMINI_TEXT_MODEL=gemini-2.5-flash
# Or: GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
# Set to 1 to skip social_captions.txt / social_captions.json after render.
# GEMINI_CAPTIONS_SKIP=1
# Scene images: primary, then GEMINI_IMAGE_MODEL_FALLBACK (optional), then built-ins:
#   gemini-3.1-flash-image-preview, gemini-3-pro-image-preview, nano-banana-pro-preview
# (deprecated gemini-2.5-flash-image-preview is not used.)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL_FALLBACK=model-a,model-b

# ─── PAYTRUST BRAND ──────────────────────────
BRAND_NAME=PayTrust
BRAND_PRIMARY_COLOR=#1F6FEB
BRAND_COUNTRY=Ghana
TARGET_AUDIENCE=Ghanaian merchants and online sellers
